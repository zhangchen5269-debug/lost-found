# 应用
APP_NAME=失物招领系统
DEBUG=false
SECRET_KEY=please-change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库（异步 URL；Alembic 会自动推导同步 URL）
DATABASE_URL=sqlite+aiosqlite:///dev.db

# 上传目录与对外访问前缀（需与 main 中 StaticFiles 路径一致）
UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_BASE_URL=http://127.0.0.1:8000/static/uploads
